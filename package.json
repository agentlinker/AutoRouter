{
  "name": "autorouter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local trusted model provider router for agent clients.",
  "scripts": {
    "dev": "npm run build:admin && tsx src/main.ts",
    "dev:server": "tsx src/main.ts",
    "dev:admin": "vite --config vite.admin.config.ts --host 127.0.0.1 --port 5173",
    "build": "npm run build:admin && tsup src/main.ts --format esm --dts --clean",
    "build:admin": "vite build --config vite.admin.config.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.admin.json --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "lucide-react": "^1.23.0",
    "parquetjs-lite": "^0.8.7",
    "pino": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "undici": "^7.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
